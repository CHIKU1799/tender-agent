# ════════════════════════════════════════════════════════════
#  Tender Agent — Environment Configuration
# ════════════════════════════════════════════════════════════

# ── OpenAI API Key ────────────────────────────────────────────────────────────
# Used for: image/text CAPTCHA solving (GPT-4o vision) + audio CAPTCHA (Whisper)
# Get yours at: https://platform.openai.com/api-keys
# Required for archive/awards pages (which have image CAPTCHAs)
OPENAI_API_KEY=sk-proj-your-key-here

# ── 2Captcha API Key ──────────────────────────────────────────────────────────
# Used for: reCAPTCHA v2/v3, hCaptcha — paid service, ~$1 per 1000 solves
# Get yours at: https://2captcha.com
TWOCAPTCHA_KEY=

# ── Anti-Captcha API Key ──────────────────────────────────────────────────────
# Alternative to 2Captcha for reCAPTCHA solving
# Get yours at: https://anti-captcha.com
ANTICAPTCHA_KEY=

# ── Dashboard settings ────────────────────────────────────────────────────────
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=5002

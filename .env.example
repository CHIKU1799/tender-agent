# ── OpenAI API Key — required for CAPTCHA solving on archive/awards pages ────
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-key-here

# ── Dashboard settings ────────────────────────────────────────────────────────
# Port 5002 is the default (macOS uses 5000 for AirPlay)
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=5002
